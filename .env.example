# App
FRONTEND_URL=http://localhost
CORS_ORIGINS=http://localhost,http://localhost:3000
SECRET_KEY=replace-with-strong-secret
REFRESH_SECRET_KEY=replace-with-strong-refresh-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_HOURS=24
DEBUG=false

# PostgreSQL
POSTGRES_DB=blur
POSTGRES_USER=blur_user
POSTGRES_PASSWORD=blur_password

# S3 / MinIO
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=file-processor
S3_REGION=us-east-1
PRESIGNED_URL_EXPIRY=3600

# External API
EXTERNAL_TIP_API_URL=https://api.api-ninjas.com/v1/facts
EXTERNAL_TIP_API_KEY=replace-with-api-key
EXTERNAL_TIP_TIMEOUT_SEC=3.0
EXTERNAL_TIP_MAX_RETRIES=2
EXTERNAL_TIP_RATE_LIMIT_PER_MIN=30
EXTERNAL_TIP_CACHE_TTL_SEC=300
